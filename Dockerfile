# Используем официальный Python образ на базе slim для уменьшения размера
FROM python:3.14-slim

# Устанавливаем рабочую директорию внутри контейнера
# Все команды RUN, COPY и CMD будут выполняться относительно этой папки
WORKDIR /container

# Копируем файл зависимостей и устанавливаем библиотеки
# --no-cache-dir убирает кэш pip, чтобы образ был легче
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Копируем весь проект в рабочую директорию контейнера
COPY . .

# Команда запуска приложения FastAPI через Uvicorn
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload"]
# --host 0.0.0.0 делает приложение доступным снаружи контейнера
# --port 8000 задаёт порт приложения
# --reload включает автоматическую перезагрузку при изменении кода (только для разработки)